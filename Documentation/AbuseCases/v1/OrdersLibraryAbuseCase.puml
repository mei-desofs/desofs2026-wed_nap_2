@startuml orders_library_abuse_case
left to right direction
skinparam packageStyle rectangle

actor Buyer
actor Admin
actor Attacker

rectangle "ArcadeHaven - Orders and Library" {

  Buyer --> (Create Order)
  Buyer --> (Cancel Pending Order)
  Buyer --> (View Library)
  Buyer --> (View Activation Keys)
  Admin --> (Manage Library Entries)

  Attacker --> (Order Tampering)
  Attacker --> (Duplicate Order Race)
  Attacker --> (Unauthorized Order Cancellation)
  Attacker --> (Activation Key Disclosure)
  Attacker --> (Unauthorized Library Revocation)

  (Order Tampering) ..> (Create Order) : <<abuses>>
  (Duplicate Order Race) ..> (Create Order) : <<abuses>>
  (Unauthorized Order Cancellation) ..> (Cancel Pending Order) : <<abuses>>
  (Activation Key Disclosure) ..> (View Activation Keys) : <<abuses>>
  (Unauthorized Library Revocation) ..> (Manage Library Entries) : <<abuses>>
}

@enduml